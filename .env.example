# Session secret - must be at least 32 characters, change this!
NUXT_SESSION_PASSWORD=change-this-to-a-secure-random-32-char-string!!

# Directory where markdown notes are stored (default: ~/.quickNote)
NOTES_DIR=~/.quickNote

# Users - JSON array of {username, passwordHash} objects
# Generate a hash with: node -e "const b=require('bcryptjs');b.hash('yourpassword',10).then(console.log)"
AUTH_USERS='[{"username":"admin","passwordHash":"$2a$10$REPLACEWITHYOURHASHEDPASSWORD"}]'
